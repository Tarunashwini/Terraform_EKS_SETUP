# Local .terraform folder (contains binaries/plugins)
**/.terraform/*

# .tfstate files (Contains sensitive data and infrastructure secrets)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude terraform.tfvars (contains sensitive input variables)
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore the lock file if you want to allow provider version drift 
# (Though many teams keep this for consistency)
# .terraform.lock.hcl
